{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@libs/*": ["../libs/src/*.js"],
      "@client-backend/*": ["./src/*.js"]
    }
  },
  "references": [{ "path": "../libs" }],
  "include": [
    "src/**/*",
    "../libs/src/"
  ]
}

