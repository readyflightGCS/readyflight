{
  "compilerOptions": {
    "outDir": "../dist/libs",
    "rootDir": "../",
    "declaration": true,
    "declarationMap": true,
    "moduleResolution": "Bundler",
    "composite": true,
    "paths": {
      "@libs/*": ["./src/*"],
      "@client-frontend/*": ["../client-frontend/src/*"]
    },
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],
  },
  "include": ["./src/**/*", "../client-frontend/src/**/*"]
}
